# SecureShop Environment Variables
# ================================
# WARNING: This file is for development only.
# For production, use a secure secrets management solution (e.g., HashiCorp Vault, AWS Secrets Manager)

# Database Credentials (CHANGE THESE IN PRODUCTION)
DB_USER=admin
DB_PASSWORD=changeme

# JWT Secret (CHANGE THIS IN PRODUCTION)
JWT_SECRET=dev-secret-key-change-in-production

# Payment Service Configuration
PAYMENT_API_KEY=test-key-change-in-production
ENCRYPTION_KEY=test-encryption-key

# RabbitMQ Credentials (CHANGE THESE IN PRODUCTION)
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# Email Service Configuration (for Notification Service)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Application Environment
NODE_ENV=development
PYTHON_ENV=development

# Logging Level
LOG_LEVEL=INFO

# API Configuration
API_RATE_LIMIT=100
API_TIMEOUT=30000
